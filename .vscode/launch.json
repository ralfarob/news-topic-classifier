{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Train news topic classifier",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/train.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe"
    },
    {
      "name": "Python: Predict news topic",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/predict.py",
      "args": [
        "--text",
        "Government plans a new education reform"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe"
    }
  ]
}